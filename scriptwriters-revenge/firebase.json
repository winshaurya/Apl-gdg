{
  "functions": {
    "source": "functions",
    "predeploy": [
      "npm --prefix \"$RESOURCE_DIR/..\" run build"
    ]
  },
  "hosting": [
    {
      "site": "<YOUR_FIREBASE_SITE_ID>",
      "public": "public",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "**",
          "function": "nextServer"
        }
      ]
    }
  ]
}
